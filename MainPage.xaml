<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PowerMonitorApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PowerMonitorApp.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="0,0,0,24" HorizontalAlignment="Center">
            <TextBlock Text="Total System Power" Style="{ThemeResource TitleTextBlockStyle}" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Text="{x:Bind ViewModel.SystemPowerFormatted, Mode=OneWay}" FontSize="64" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
        </StackPanel>

        <GridView Grid.Row="1" ItemsSource="{x:Bind ViewModel.HardwareComponents, Mode=OneWay}" SelectionMode="None">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:HardwareItem">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="8"
                            Padding="16"
                            Width="340"
                            Height="400">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Name}" 
                                               Style="{ThemeResource SubtitleTextBlockStyle}" 
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Bottom"/>
                                    <TextBlock Text="{x:Bind TotalLoadFormatted, Mode=OneWay}" 
                                               Style="{ThemeResource SubtitleTextBlockStyle}" 
                                               FontWeight="Normal"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Visibility="{x:Bind TotalLoadVisibility, Mode=OneWay}"
                                               VerticalAlignment="Bottom"/>
                                </StackPanel>
                                <ProgressBar Value="{x:Bind TotalLoad, Mode=OneWay}" 
                                             Visibility="{x:Bind TotalLoadVisibility, Mode=OneWay}"
                                             Maximum="100"
                                             Margin="0,8,0,0"
                                             Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                            </StackPanel>
                            
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{x:Bind Sensors, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:SensorItem">
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Name}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind Name}" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                                    <TextBlock Text="{x:Bind Value, Mode=OneWay}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{x:Bind Unit}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="4,0,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
